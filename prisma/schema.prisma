generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ✅ ENUMS FIRST
//////////////////////

enum ArticleCategory {
  LAW
  AMENDMENT
  POLICY
  CULTURE
  HISTORY
  DIVERSITY
  STATE_INSIGHT
}

enum Role {
  READER
  EDITOR
  ADMIN
}

//////////////////////
// ✅ MODELS
//////////////////////

model Article {
  id             String          @id @default(cuid())
  slug           String          @unique
  title          String
  category       ArticleCategory
  summary        String?
  body           String
  impactAnalysis String?
  stateId        String?
  tags           String[]        @default([])
  embedding      Float[]         @default([])
  publishedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  state       State?            @relation(fields: [stateId], references: [id])
  relatedFrom ArticleRelation[] @relation("ArticleRelatedFrom")
  relatedTo   ArticleRelation[] @relation("ArticleRelatedTo")
  bookmarks   Bookmark[]

  @@index([category])
  @@index([stateId])
  @@index([publishedAt])
}

model ArticleRelation {
  fromId String
  toId   String

  from Article @relation("ArticleRelatedFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   Article @relation("ArticleRelatedTo", fields: [toId], references: [id], onDelete: Cascade)

  @@id([fromId, toId])
}

model State {
  id       String    @id @default(cuid())
  name     String    @unique
  code     String    @unique
  articles Article[]
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  image         String?
  emailVerified DateTime?

  role      Role     @default(READER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookmarks Bookmark[]
  accounts  Account[]
  sessions  Session[]
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
